    //     key: "group-matches",
    //     label: "Partidos (Grupos)",
    //     title: "Torneo de Fútbol – Partidos (Grupos)",
    //     src: "https://www.score7.io/embed/tournaments/ezplaysoccer/stages/26082624?showName=true&theme=dark",
    // },
    // {
    //     key: "standings",
    //     label: "Tabla",
    //     title: "Torneo de Fútbol – Tabla",
    //     src: "https://www.score7.io/embed/tournaments/ezplaysoccer/standings/26082624?showName=true&theme=dark",
    // },
    // {
    //     key: "stats",
    //     label: "Estadísticas",
    //     title: "Torneo de Fútbol – Estadísticas",
    //     src: "https://www.score7.io/embed/tournaments/ezplaysoccer/stats?showName=true&theme=dark",
    // },
    // {
    //     key: "elims",
    //     label: "Eliminatoria",
    //     title: "Torneo de Fútbol – Eliminatoria",
    //     src: "https://www.score7.io/embed/tournaments/ezplaysoccer/stages/26082632?showName=true&theme=dark",
    // },
] as const;

// 🏐 Vóley
const volleyIframes: Readonly<ScoreEmbed[]> = [
    {
        key: "overview",
        label: "Descripción",
        title: "Vóley Playa – Descripción",
        src: "https://www.score7.io/embed/tournaments/hqo36nmky4/overview?showName=true&theme=dark",
    },
    {
        key: "teams",
        label: "Equipos",
        title: "Vóley Playa – Equipos",
        src: "https://www.score7.io/embed/tournaments/hqo36nmky4/participants?showName=true&theme=dark",
    },
    // {
    //     key: "group-matches",
    //     label: "Partidos (Grupos)",
    //     title: "Vóley Playa – Partidos (Grupos)",
    //     src: "https://www.score7.io/embed/tournaments/hqo36nmky4/stages/26349353?showName=true&theme=dark",
    // },
