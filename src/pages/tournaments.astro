        title: "Torneo de Fútbol – Descripción",
        src: "https://www.score7.io/embed/tournaments/ezplaysoccer/overview?showName=true&theme=dark",
    },
    {
        key: "teams",
        label: "Equipos",
        title: "Torneo de Fútbol – Equipos",
        src: "https://www.score7.io/embed/tournaments/ezplaysoccer/participants?showName=true&theme=dark",
    },
