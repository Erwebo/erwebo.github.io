---
import { getCollection, render } from "astro:content";
import BlogLayout from "../../layouts/BlogLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const SITE = "https://ezplayapp.com";
const canonical = `${SITE}/blog/${post.id}`;
const ogImage = post.data.heroImage ? `${SITE}${post.data.heroImage}` : `${SITE}/og-ezplay.jpg`;

const fmt = (d: Date) =>
  new Intl.DateTimeFormat("es-PA", { timeZone: "America/Panama", day: "numeric", month: "long", year: "numeric" }).format(d);

const schema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.data.title,
  "description": post.data.description,
  "datePublished": post.data.pubDate.toISOString(),
  "dateModified": (post.data.updatedDate ?? post.data.pubDate).toISOString(),
  "image": ogImage,
  "inLanguage": "es-PA",
  "mainEntityOfPage": { "@type": "WebPage", "@id": canonical },
  "author": { "@type": "Organization", "name": "EZ Play", "url": SITE },
  "publisher": {
    "@type": "Organization",
    "name": "EZ Play",
    "logo": { "@type": "ImageObject", "url": `${SITE}/assets/Logo%20(PNG)/Logo%20EZPlay%206%20transparent.png` },
  },
};
---

<BlogLayout title={`${post.data.title} | EZ Play`} description={post.data.description} canonical={canonical} ogImage={ogImage}>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} slot="head" />

  <article class="post">
    <div class="container post-inner">
      <a href="/blog" class="post-back">← Volver al blog</a>
      <time datetime={post.data.pubDate.toISOString()}>{fmt(post.data.pubDate)}</time>
      <h1>{post.data.title}</h1>
      <p class="post-lead">{post.data.description}</p>
      {post.data.heroImage && (
        <div class="post-hero"><img src={post.data.heroImage} alt={post.data.heroAlt ?? post.data.title} /></div>
      )}
      <div class="prose">
        <Content />
      </div>

      <div class="post-cta">
        <p>¿Listo para jugar? Reserva tu cupo en la app y llega a jugar — cancha, árbitro, balón y petos incluidos.</p>
        <div class="post-cta-btns">
          <a href="https://apps.apple.com/pa/app/ez-play/id6446805916" target="_blank" rel="noopener" class="btn btn-red">App Store</a>
          <a href="https://play.google.com/store/apps/details?id=com.r2e.EZPlay&pcampaignid=web_share" target="_blank" rel="noopener" class="btn btn-outline">Google Play</a>
        </div>
      </div>
    </div>
  </article>
</BlogLayout>

<style>
  .post { padding: 50px 0; }
  .post-inner { max-width: 760px; }
  .post-back { color: var(--g2); font-size: .85rem; }
  .post-back:hover { color: var(--white); }
  .post time { display: block; color: var(--g3); font-size: .8rem; text-transform: uppercase; letter-spacing: .05em; margin-top: 20px; }
  .post h1 { font-family: 'Barlow Condensed', sans-serif; font-size: clamp(2rem, 5vw, 3.4rem); font-weight: 900; text-transform: uppercase; line-height: 1.02; margin: .4rem 0 1rem; }
  .post-lead { color: var(--g1); font-size: 1.15rem; line-height: 1.6; margin-bottom: 1.6rem; }
  .post-hero { border-radius: 14px; overflow: hidden; margin-bottom: 2rem; }
  .post-hero img { width: 100%; height: auto; display: block; }

  .prose { color: var(--g1); line-height: 1.8; font-size: 1.05rem; }
  .prose :global(h2) { font-family: 'Barlow Condensed', sans-serif; font-size: 1.7rem; font-weight: 800; text-transform: uppercase; color: var(--white); margin: 2.2rem 0 .8rem; }
  .prose :global(h3) { font-size: 1.2rem; font-weight: 700; color: var(--white); margin: 1.6rem 0 .6rem; }
  .prose :global(p) { margin: 0 0 1.1rem; color: var(--g1); }
  .prose :global(ul), .prose :global(ol) { margin: 0 0 1.1rem 1.2rem; display: flex; flex-direction: column; gap: .5rem; }
  .prose :global(li) { color: var(--g1); }
  .prose :global(a) { color: var(--red); text-decoration: underline; }
  .prose :global(a:hover) { color: #e00000; }
  .prose :global(strong) { color: var(--white); }
  .prose :global(blockquote) { border-left: 3px solid var(--red); padding-left: 18px; color: var(--g2); font-style: italic; margin: 1.4rem 0; }

  .post-cta { margin-top: 3rem; padding: 30px; background: var(--bg2); border: 1px solid var(--border); border-radius: 14px; text-align: center; }
  .post-cta p { color: var(--g1); margin-bottom: 1.2rem; }
  .post-cta-btns { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
</style>
