<script is:inline>
  /* NAV */
  const nav = document.getElementById('nav');
  window.addEventListener('scroll', () => {
    nav.classList.toggle('scrolled', window.scrollY > 50);
  }, { passive: true });

  /* Mobile menu */
  const hamb = document.getElementById('hamburger');
  hamb.addEventListener('click', () => {
    document.getElementById('mobileNav').classList.add('open');
    hamb.setAttribute('aria-expanded', 'true');
  });
  document.getElementById('mobileClose').addEventListener('click', closeMob);
  function closeMob() {
    document.getElementById('mobileNav').classList.remove('open');
    hamb.setAttribute('aria-expanded', 'false');
  }

  /* Scroll reveal */
  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
  document.querySelectorAll('.reveal, .reveal-left, .reveal-right').forEach(el => io.observe(el));

  /* Parallax hero */
  const heroBgImg = document.querySelector('.hero-bg img');
  const heroContent = document.querySelector('.hero-content');
  window.addEventListener('scroll', () => {
    const y = window.scrollY;
    if (heroBgImg) heroBgImg.style.transform = `translateY(${y * 0.22}px)`;
    if (heroContent && y < window.innerHeight) {
      heroContent.style.transform = `translateY(${y * 0.12}px)`;
    }
  }, { passive: true });

  /* Smooth scroll */
  document.querySelectorAll('a[href^="#"]').forEach(a => {
    a.addEventListener('click', function(e) {
      const href = this.getAttribute('href');
      if (href === '#') return;
      const el = document.querySelector(href);
      if (!el) return;
      e.preventDefault();
      window.scrollTo({ top: el.getBoundingClientRect().top + window.scrollY - 80, behavior: 'smooth' });
    });
  });


  /* Demo: fechas dinámicas para los partidos placeholder
     (se reemplazan automáticamente cuando el endpoint esté conectado) */
  (function fillDemoDates(){
    const meses = ['Ene','Feb','Mar','Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic'];
    const dias  = ['Dom','Lun','Mar','Mié','Jue','Vie','Sáb'];
    const today = new Date();
    function next(targetDow) {
      const d = new Date(today);
      const diff = (targetDow - d.getDay() + 7) % 7 || 7;
      d.setDate(d.getDate() + diff);
      return d;
    }
    document.querySelectorAll('.partido-day[data-day]').forEach(el => {
      const tag = el.dataset.day;
      const d = tag === 'next-sun' ? next(0) : next(6);
      el.textContent = `${dias[d.getDay()]} ${d.getDate()} ${meses[d.getMonth()]}`;
    });
  })();

  /* Counter animation */
  function animateCount(el, target, suffix = '') {
    let start = 0;
    const dur = 1400;
    const fmt = (n) => n.toLocaleString('en-US');
    const step = (ts) => {
      if (!start) start = ts;
      const prog = Math.min((ts - start) / dur, 1);
      const ease = 1 - Math.pow(1 - prog, 3);
      el.textContent = fmt(Math.floor(ease * target)) + suffix;
      if (prog < 1) requestAnimationFrame(step);
      else el.textContent = fmt(target) + suffix;
    };
    requestAnimationFrame(step);
  }
  new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.querySelectorAll('.stat-num[data-count]').forEach(n => {
          animateCount(n, parseInt(n.dataset.count), n.dataset.suffix || '');
        });
      }
    });
  }, { threshold: 0.5 }).observe(document.querySelector('.hero-stats'));

  /* Cupos bar animation on scroll */
  const cuposObs = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.querySelectorAll('.cupos-fill').forEach(bar => {
          const w = bar.style.width;
          bar.style.width = '0';
          setTimeout(() => { bar.style.transition = 'width 1s cubic-bezier(.22,1,.36,1)'; bar.style.width = w; }, 100);
        });
        cuposObs.unobserve(e.target);
      }
    });
  }, { threshold: 0.2 });
  document.querySelectorAll('.partido-card').forEach(c => cuposObs.observe(c));

  /* ──────────────────────────────────────────────────────────
     PARTIDOS EN TIEMPO REAL
     ──────────────────────────────────────────────────────────
     Cuando el equipo de desarrollo te dé la URL del endpoint,
     pégala en PARTIDOS_API abajo. Nada más que cambiar.

     El endpoint debe devolver un array JSON con este formato:
     [
       {
         "deporte":        "futbol" | "volley_arena" | "volley_piso",
         "fecha":          "2024-04-26",
         "hora_inicio":    "07:00",
         "hora_fin":       "09:00",
         "venue":          "Costa del Este",
         "cupos_total":    20,
         "cupos_ocupados": 14,
         "precio":         6.50,
         "formato":        "10 vs 10",
         "genero":         "Masculino" | "Mixto",
         "nivel":          "General" | "Intermedio",
         "estado":         "disponible" | "lleno" | "cancelado",
         "foto_url":       null  // opcional, si existe usa esa foto
       },
       ...
     ]

     Si el endpoint usa Supabase directo (no una API propia),
     descomenta PARTIDOS_HEADERS y pon tu anon key:
  ────────────────────────────────────────────────────────── */

  const PARTIDOS_API = 'https://ezplay-prod.onrender.com/public/games/active';

  /* === Adaptadores de la API EZ Play === */
  const _TZ = 'America/Panama';
  const _GAMETYPE_MAP = {
    SOCCER: 'futbol',
    VOLLEYBALL_BEACH: 'volley_arena',
    VOLLEYBALL_INDOOR: 'volley_piso',
  };
  const _GENDER_MAP = { MALE: 'Masculino', FEMALE: 'Femenino', MIXED: 'Mixto' };
  const _LEVEL_MAP  = { BEGINNER: 'Principiante', INTERMEDIATE: 'Intermedio', ADVANCED: 'Avanzado' };

  const _fechaLabelFmt = new Intl.DateTimeFormat('es-PA', { timeZone: _TZ, weekday:'short', day:'numeric', month:'short' });
  const _hora12Fmt     = new Intl.DateTimeFormat('en-US',  { timeZone: _TZ, hour:'numeric', minute:'2-digit', hour12:true });

  function _toDate(iso) {
    if (!iso) return null;
    const d = new Date(iso);
    return isNaN(d) ? null : d;
  }
  /* "lun., 12 may." → "lun 12 may" (el CSS lo pasa a mayúsculas) */
  function _fmtFechaLabel(d) {
    return d ? _fechaLabelFmt.format(d).replace(/[.,]/g, '').replace(/\s+/g, ' ').trim() : '';
  }
  /* Rango de horas en 12h: "7:00–9:00 AM" cuando comparten periodo,
     "11:30 AM – 1:00 PM" cuando lo cruzan. */
  function _fmtHoraRange(start, end) {
    if (!start || !end) return '';
    const s = _hora12Fmt.format(start);   // "7:00 AM"
    const e = _hora12Fmt.format(end);     // "9:00 AM"
    const sP = s.slice(-2), eP = e.slice(-2);
    if (sP === eP) return `${s.slice(0, -3)}–${e.slice(0, -3)} ${sP}`;
    return `${s} – ${e}`;
  }

  function _adaptGame(g) {
    const pd    = g.placeDetails || {};
    const loc   = pd.location || {};
    const start = _toDate(g.startDate);
    const end   = _toDate(g.endDate);
    const ocup  = Array.isArray(g.players) ? g.players.length : 0;
    const tot   = Number(g.maxPlayers) || 0;
    const foto  = Array.isArray(pd.imgs) && pd.imgs.length ? pd.imgs[0] : null;
    return {
      deporte:        _GAMETYPE_MAP[g.gameType] || g.gameType,
      fecha_label:    _fmtFechaLabel(start),
      horario:        _fmtHoraRange(start, end),
      venue:          pd.name || loc.fullAddress || g.place || '',
      cupos_total:    tot,
      cupos_ocupados: ocup,
      precio:         Number(g.price) || 0,
      formato:        g.teamPlayers ? `${g.teamPlayers} vs ${g.teamPlayers}` : '',
      genero:         _GENDER_MAP[g.genderType] || '',
      nivel:          _LEVEL_MAP[g.level] || 'General',
      estado:         g.status === false ? 'cancelado' : (tot > 0 && ocup >= tot ? 'lleno' : 'disponible'),
      foto_url:       foto,
    };
  }

  const _SPORT_FOTO  = {
    futbol:       '/assets/fotos/futbol-1.jpg',
    volley_arena: '/assets/fotos/volley-arena-2.jpg',
    volley_piso:  '/assets/fotos/volley-piso-1.jpg',
  };
  const _SPORT_ICON  = { futbol:`<img class="sport-icon" src="/assets/icons/soccer-icon.svg" alt="">`, volley_arena:`<img class="sport-icon" src="/assets/icons/volley-beach-icon.svg" alt="">`, volley_piso:`<img class="sport-icon" src="/assets/icons/volley-indoor-icon.svg" alt="">` };
  const _SPORT_LABEL = { futbol:'Fútbol Masculino', volley_arena:'Vóley Playa', volley_piso:'Vóley Piso' };
  const _PIN_SVG     = `<i class="fa-solid fa-location-dot"></i>`;
  const _LOGO        = '/assets/Logo%20(PNG)/Logo%20EZPlay%206%20transparent.png';

  function _buildCard(p) {
    const libres  = Math.max(0, (p.cupos_total || 20) - (p.cupos_ocupados || 0));
    const pct     = Math.min(100, Math.round(((p.cupos_ocupados || 0) / (p.cupos_total || 20)) * 100));
    const stCls   = libres === 0 ? 'status-full' : libres <= 3 ? 'status-few' : 'status-ok';
    const stLbl   = libres === 0 ? 'Lleno' : `${libres} cupos disponibles`;
    const foto    = p.foto_url || _SPORT_FOTO[p.deporte] || _SPORT_FOTO.futbol;
    const icon    = _SPORT_ICON[p.deporte]  || '🏅';
    const dlbl    = _SPORT_LABEL[p.deporte] || p.deporte;
    const precio  = Number(p.precio || 6.5).toFixed(2);
    const fechaStr = p.fecha_label || '';
    const horaStr  = p.horario || '';
    const _g = (p.genero || '').toLowerCase();
    const genIcon = _g.includes('masc') ? '<i class="fa-solid fa-person"></i>' : _g.includes('fem') ? '<i class="fa-solid fa-person-dress"></i>' : '<i class="fa-solid fa-person"></i><i class="fa-solid fa-person-dress"></i>';
    return `
<div class="partido-card reveal">
  <div class="partido-img">
    <img src="${foto}" alt="${dlbl}" loading="lazy" />
    <span class="partido-badge-sport">${icon} ${dlbl}</span>
    <span class="partido-badge-status ${stCls}">${stLbl}</span>
    <span class="partido-price-badge">$${precio}</span>
  </div>
  <div class="partido-body">
    <div class="partido-datetime">
      <span class="partido-day">${fechaStr}</span>
      <span class="partido-time">${horaStr}</span>
    </div>
    <div class="partido-venue">${_PIN_SVG} ${p.venue || ''} · Panamá</div>
    <div class="cupos-track"><div class="cupos-fill" style="width:${pct}%"></div></div>
    <div class="cupos-meta">
      <span class="cupos-text">${p.cupos_ocupados || 0} de ${p.cupos_total || 20} cupos</span>
      <span class="cupos-num">${libres} libres</span>
    </div>
    <div class="partido-info-row">
      <span class="partido-info-pill">${icon} ${p.formato || ''}</span>
      <span class="partido-info-pill">${genIcon} ${p.genero || ''}</span>
      <span class="partido-info-pill">${p.nivel || ''}</span>
      <span class="partido-organizer"><img src="${_LOGO}" alt="EZ Play" /> EZ Play</span>
    </div>
    <div class="partido-foot">
      <div class="partido-price">$${precio} <small>/ cupo</small></div>
      ${libres > 0
        ? `<a href="#app" class="btn-reservar">Reservar →</a>`
        : `<span class="btn-reservar" style="opacity:.45;cursor:default;pointer-events:none;">Lleno</span>`}
    </div>
  </div>
</div>`;
  }

  async function loadPartidos() {
    if (PARTIDOS_API === 'PEGAR_URL_AQUI') return;
    const grid = document.getElementById('partidos-grid-dynamic');
    if (!grid) return;
    try {
      const opts = typeof PARTIDOS_HEADERS !== 'undefined' ? { headers: PARTIDOS_HEADERS } : {};
      const res  = await fetch(PARTIDOS_API, opts);
      if (!res.ok) throw new Error('HTTP ' + res.status);
      const raw  = await res.json();
      const games = raw?.data?.games || (Array.isArray(raw) ? raw : raw?.data || []);
      const list = games
        .slice()
        .sort((a, b) => new Date(a.startDate || 0) - new Date(b.startDate || 0))
        .map(_adaptGame)
        .filter(p => p.estado !== 'cancelado')
        .slice(0, 3);
      if (list.length === 0) return;
      grid.innerHTML = list.map(_buildCard).join('');
      grid.querySelectorAll('.partido-card').forEach(c => { io.observe(c); cuposObs.observe(c); });
      const upd = document.getElementById('partidos-updated');
      const t   = document.getElementById('partidos-updated-time');
      if (upd && t) {
        const now = new Date();
        t.textContent = now.toLocaleTimeString('es-PA', { hour:'2-digit', minute:'2-digit' });
        upd.style.display = 'block';
      }
    } catch(err) {
      console.warn('[EZ Play] API de partidos no disponible, se muestran los partidos de ejemplo.', err);
    }
  }

  loadPartidos();
  setInterval(loadPartidos, 60000);

  /* ──────────────────────────────────────────────────────────
     MVPs EN TIEMPO REAL
     ──────────────────────────────────────────────────────────
     Cuando el equipo te dé la URL del endpoint,
     pégala en MVPS_API abajo. Nada más que cambiar.

     El endpoint debe devolver un array JSON con este formato:
     [
       {
         "rank":         1,
         "nombre":       "Kriss",
         "deporte":      "volley_arena" | "futbol" | "volley_piso",
         "partidos_mvp": 3,
         "foto_url":     null   // URL de foto de perfil, opcional
       },
       ...
     ]

     Si el endpoint usa Supabase directo (no una API propia),
     descomenta MVPS_HEADERS y pon tu anon key:
  ────────────────────────────────────────────────────────── */

  const MVPS_API = 'https://ezplay-prod.onrender.com/public/mvp/weekly';

  /* Formatea created_at de un MVP como etiqueta tipo "DOM 10 MAY" en zona
     horaria America/Panama. */
  const _DOW_ES = { Sun:'DOM', Mon:'LUN', Tue:'MAR', Wed:'MIE', Thu:'JUE', Fri:'VIE', Sat:'SAB' };
  const _MON_ES = { Jan:'ENE', Feb:'FEB', Mar:'MAR', Apr:'ABR', May:'MAY', Jun:'JUN', Jul:'JUL', Aug:'AGO', Sep:'SEP', Oct:'OCT', Nov:'NOV', Dec:'DIC' };
  const _mvpDateParts = new Intl.DateTimeFormat('en-US', { timeZone: _TZ, weekday:'short', day:'numeric', month:'short' });
  function _fmtMvpDate(iso) {
    const d = _toDate(iso);
    if (!d) return '';
    const parts = _mvpDateParts.formatToParts(d);
    const get = t => (parts.find(p => p.type === t) || {}).value || '';
    return `${_DOW_ES[get('weekday')] || ''} ${get('day')} ${_MON_ES[get('month')] || ''}`.trim();
  }

  /* La API devuelve los registros por fecha descendente (más recientes
     primero). Tomamos los 3 MVPs más recientes (deduplicando por usuario,
     conservando su aparición más reciente como fecha mostrada) y
     contamos cuántas veces fue MVP en la ventana de 7 días. */
  function _adaptMvps(records) {
    const byUid = new Map();
    const order = [];
    for (const r of records || []) {
      if (!r || !r.uid) continue;
      if (!byUid.has(r.uid)) {
        const fullName = `${r.firstname || ''} ${r.lastname || ''}`.trim();
        byUid.set(r.uid, {
          uid: r.uid,
          nombre: r.alias || fullName || 'MVP',
          deporte: _GAMETYPE_MAP[r.gameType] || r.gameType,
          partidos_mvp: 0,
          foto_url: r.profilePic || null,
          fecha_label: _fmtMvpDate(r.created_at),
        });
        order.push(r.uid);
      }
      byUid.get(r.uid).partidos_mvp += 1;
    }
    return order.slice(0, 3).map(uid => byUid.get(uid));
  }

  const _MVP_SPORT_LABEL = {
    futbol:       `<img class="sport-icon" src="/assets/icons/soccer-icon.svg" alt=""> Fútbol`,
    volley_arena: '<img class="sport-icon" src="/assets/icons/volley-beach-icon.svg" alt=""> Vóley Playa',
    volley_piso:  '<img class="sport-icon" src="/assets/icons/volley-indoor-icon.svg" alt=""> Vóley Piso',
  };

  function _buildMvpCard(m) {
    const sport   = _MVP_SPORT_LABEL[m.deporte] || m.deporte || '';
    const initial = (m.nombre || '?')[0].toUpperCase();
    const avatar  = m.foto_url
      ? `<img src="${m.foto_url}" alt="${m.nombre}" />`
      : initial;
    const label   = m.fecha_label || 'MVP';
    return `
<div class="mvp-card reveal">
  <span class="mvp-rank">${label}</span>
  <div class="mvp-avatar">${avatar}</div>
  <div class="mvp-name">${m.nombre || ''}</div>
  <div class="mvp-sport">${sport}</div>
</div>`;
  }

  async function loadMVPs() {
    if (MVPS_API === 'PEGAR_URL_AQUI') return;
    const grid = document.querySelector('.mvps-grid');
    if (!grid) return;
    try {
      const opts = typeof MVPS_HEADERS !== 'undefined' ? { headers: MVPS_HEADERS } : {};
      const res  = await fetch(MVPS_API, opts);
      if (!res.ok) throw new Error('HTTP ' + res.status);
      const raw  = await res.json();
      const records = raw?.data?.records || (Array.isArray(raw) ? raw : raw?.data || []);
      const list = _adaptMvps(records);
      if (list.length === 0) return;
      grid.innerHTML = list.map(_buildMvpCard).join('');
      grid.querySelectorAll('.mvp-card').forEach(el => io.observe(el));
    } catch(err) {
      console.warn('[EZ Play] API de MVPs no disponible, se muestran los MVPs de ejemplo.', err);
    }
  }

  loadMVPs();
  setInterval(loadMVPs, 300000); // refresca cada 5 minutos
</script>

</MainLayout>
