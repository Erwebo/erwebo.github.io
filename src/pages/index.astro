---
import MainLayout from "../layouts/MainLayout.astro";
import heroImg from "../assets/image1.png";
import benefitsImg from "../assets/benefits.jpg";
import contactImg from "../assets/contact.jpg";

const PLAY_STORE_URL =
  "https://play.google.com/store/apps/details?id=com.r2e.EZPlay";
const APP_STORE_URL = "https://apps.apple.com/pa/app/ez-play/id6446805916";
---

<MainLayout
  title="EZ PLAY - Organizamos los partidos, tú solo llegas y juegas"
  description="EZ PLAY es la forma más fácil de unirte a partidos organizados de fútbol y voleibol en Panamá. Pagas tu cupo desde la app, llegas a la cancha y encuentras todo listo para jugar."
  canonicalUrl="https://ezplayapp.com/"
>
  <!-- HERO -->
  <section
    class="border-b border-white/5 bg-slate-950 relative"
    style={`background-image: url(${heroImg.src});
          background-size: cover;
          background-position: center;`}
  >
    <div class="absolute inset-0 bg-black/60"></div>
    <div
      class="relative mx-auto grid max-w-6xl gap-10 px-4 py-16 md:grid-cols-[1.1fr,0.9fr] md:py-20 lg:py-24"
    >
      <!-- Texto -->
      <div class="flex flex-col justify-center gap-6">
        <!-- <span
          class="inline-flex w-fit items-center gap-2 rounded-full border border-primary/40 bg-slate-900/70 px-3 py-1 text-xs font-medium text-primary/80"
        >
          • Juega sin preocuparte por la organización
        </span> -->

        <div
          class="flex flex-col md:flex-row items-center md:items-start gap-6 max-w-6xl"
        >
          <!-- TEXTO (60%) -->
          <h1
            class="md:basis-3/5 text-balance text-4xl font-bold tracking-tight sm:text-5xl lg:text-6xl leading-tight text-center md:text-left"
          >
            Reserva tu <span class="text-primary">cupo</span> en segundos. Nosotros
            nos encargamos del resto.
          </h1>
        </div>

        <p
          class="text-balance
         text-base sm:text-lg md:text-xl
         leading-relaxed
         text-slate-100/90
         drop-shadow-[0_2px_6px_rgba(0,0,0,0.75)]
         max-w-xl
         text-center md:text-left"
        >
          EZ PLAY es la forma más fácil de unirte a partidos recreativos
          organizados en Panamá. Reservas tu cupo desde la app, llegas a la
          cancha y todo está listo para jugar.
        </p>

        <div
          class="flex flex-wrap items-center gap-4 justify-center md:justify-start"
        >
          <a
            href={PLAY_STORE_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-xl border border-slate-600 px-5 py-2.5 text-sm font-semibold text-slate-100 hover:border-primary/70 hover:text-primary/80"
          >
            Descarga la app | Android
          </a>

          <a
            href={APP_STORE_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-xl border border-slate-600 px-5 py-2.5 text-sm font-semibold text-slate-100 hover:border-primary/70 hover:text-primary/80"
          >
            Descarga la app | iOS
          </a>
        </div>

        <div class="mt-4 grid gap-4 text-slate-100 sm:grid-cols-3">
          <div class="flex items-center gap-3">
            <span
              class="inline-flex h-7 w-7 items-center justify-center rounded-full
             bg-primary/20 text-sm font-bold text-primary
             drop-shadow-[0_2px_4px_rgba(0,0,0,0.6)]"
            >
              ✓
            </span>
            <span
              class="text-base leading-snug drop-shadow-[0_2px_4px_rgba(0,0,0,0.6)]"
            >
              Equipos, balones y organización incluida.
            </span>
          </div>

          <div class="flex items-center gap-3">
            <span
              class="inline-flex h-7 w-7 items-center justify-center rounded-full
             bg-primary/20 text-sm font-bold text-primary
             drop-shadow-[0_2px_4px_rgba(0,0,0,0.6)]"
            >
              ✓
            </span>
            <span
              class="text-base leading-snug drop-shadow-[0_2px_4px_rgba(0,0,0,0.6)]"
            >
              Paga tu cupo desde el celular.
            </span>
          </div>

          <div class="flex items-center gap-3">
            <span
              class="inline-flex h-7 w-7 items-center justify-center rounded-full
             bg-primary/20 text-sm font-bold text-primary
             drop-shadow-[0_2px_4px_rgba(0,0,0,0.6)]"
            >
              ✓
            </span>
            <span
              class="text-base leading-snug drop-shadow-[0_2px_4px_rgba(0,0,0,0.6)]"
            >
              Solo llegas y juegas.
            </span>
          </div>
        </div>
      </div>

      <!-- "Mockup" de partidos -->
      <div class="flex items-center justify-center">
        <div
          class="w-full max-w-md rounded-3xl border border-white/10 bg-slate-900/80 p-4 shadow-2xl shadow-primary/10"
        >
          <div class="mb-3 flex items-center justify-between">
            <div>
              <p class="text-xs uppercase tracking-wide text-slate-400">Hoy</p>
              <p class="text-sm font-semibold text-slate-100">
                Partidos disponibles
              </p>
            </div>
            <span
              class="rounded-full bg-primary/10 px-3 py-1 text-xs font-semibold text-primary/80"
            >
              EZ PLAY
            </span>
          </div>

          <div class="space-y-3 text-sm">
            <div
              class="flex items-center justify-between rounded-2xl bg-slate-800/80 px-3 py-3"
            >
              <div>
                <p class="font-semibold text-slate-50">Fútbol 5 - Masculino</p>
                <p class="text-xs text-slate-400">
                  Hoy · 8:00 p.m. · EZ Play Stadium
                </p>
              </div>
              <div class="text-right">
                <p class="text-xs text-slate-400">Cupos</p>
                <p class="text-sm font-semibold text-primary">4 disponibles</p>
              </div>
            </div>

            <div
              class="flex items-center justify-between rounded-2xl bg-slate-800/60 px-3 py-3"
            >
              <div>
                <p class="font-semibold text-slate-50">
                  Voleibol mixto | Arena
                </p>
                <p class="text-xs text-slate-400">
                  Jueves · 9:00 p.m. · Xspark
                </p>
              </div>
              <div class="text-right">
                <p class="text-xs text-slate-400">Cupos</p>
                <p class="text-sm font-semibold text-primary">2 disponibles</p>
              </div>
            </div>

            <div
              class="flex items-center justify-between rounded-2xl bg-slate-800/40 px-3 py-3"
            >
              <div>
                <p class="font-semibold text-slate-50">Voleibol mixto | Piso</p>
                <p class="text-xs text-slate-400">Sábado · 5:30 p.m. · IPA</p>
              </div>
              <div class="text-right">
                <p class="text-xs text-slate-400">Cupos</p>
                <p class="text-sm font-semibold text-primary">6 disponibles</p>
              </div>
            </div>
          </div>

          <p class="mt-4 text-xs text-slate-400">
            *Ejemplo ilustrativo. Descarga la app para ver los partidos reales
            de esta semana.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CÓMO FUNCIONA -->
  <section id="como-funciona" class="border-b border-white/5 bg-slate-950">
    <div class="mx-auto max-w-6xl px-4 py-12 md:py-16">
      <div class="mb-8 max-w-2xl">
        <h2 class="text-2xl font-semibold tracking-tight sm:text-3xl">
          ¿Cómo funciona EZ PLAY?
        </h2>
        <p class="mt-3 text-sm text-slate-300 sm:text-base">
          Diseñamos EZ PLAY para que jugar sea tan simple como reservar un ride:
          escoges el partido, pagas tu cupo y listo.
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-4">
        <div class="rounded-2xl border border-white/5 bg-slate-900/60 p-4">
          <p
            class="text-xs font-semibold uppercase tracking-wide text-primary/80"
          >
            Paso 1
          </p>
          <h3 class="mt-2 text-base font-semibold">Elige tu partido</h3>
          <p class="mt-2 text-sm text-slate-300">
            Abre EZ PLAY, elige el deporte y el horario que mejor te funcione.
          </p>
        </div>
        <div class="rounded-2xl border border-white/5 bg-slate-900/60 p-4">
          <p
            class="text-xs font-semibold uppercase tracking-wide text-primary/80"
          >
            Paso 2
          </p>
          <h3 class="mt-2 text-base font-semibold">Reserva tu cupo</h3>
          <p class="mt-2 text-sm text-slate-300">
            Pagas tu espacio desde la app con los métodos disponibles y aseguras
            tu lugar.
          </p>
        </div>
        <div class="rounded-2xl border border-white/5 bg-slate-900/60 p-4">
          <p
            class="text-xs font-semibold uppercase tracking-wide text-primary/80"
          >
            Paso 3
          </p>
          <h3 class="mt-2 text-base font-semibold">Llega a la cancha</h3>
          <p class="mt-2 text-sm text-slate-300">
            Un organizador EZ PLAY estará en sitio con petos, balones,
            cronómetro y todo lo necesario según el deporte.
          </p>
        </div>
        <div class="rounded-2xl border border-white/5 bg-slate-900/60 p-4">
          <p
            class="text-xs font-semibold uppercase tracking-wide text-primary/80"
          >
            Paso 4
          </p>
          <h3 class="mt-2 text-base font-semibold">Solo juegas</h3>
          <p class="mt-2 text-sm text-slate-300">
            Nos encargamos de la organización para que tú solo tengas que
            disfrutar el partido.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- DEPORTES -->
  <!-- <section id="deportes" class="border-b border-white/5 bg-slate-950/90">
    <div class="mx-auto max-w-6xl px-4 py-12 md:py-16">
      <div class="mb-8 max-w-2xl">
        <h2 class="text-2xl font-semibold tracking-tight sm:text-3xl">
          Deportes disponibles
        </h2>
        <p class="mt-3 text-sm text-slate-300 sm:text-base">
          EZ PLAY es una plataforma pensada para múltiples deportes. Hoy tenemos
          fútbol y voleibol, pero seguimos abriendo espacio para nuevas
          disciplinas.
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-3">
        <div class="rounded-2xl border border-primary/40 bg-slate-900/70 p-4">
          <p
            class="text-xs font-semibold uppercase tracking-wide text-primary/80"
          >
            Fútbol
          </p>
          <h3 class="mt-2 text-base font-semibold">Albrook Gol, TripleShot</h3>
          <p class="mt-2 text-sm text-slate-300">
            Partidos recreativos organizados en diferentes canchas de Panamá.
            Intensidad sana con árbitros para mantener el orden.
          </p>
        </div>

        <div class="rounded-2xl border border-white/10 bg-slate-900/60 p-4">
          <p
            class="text-xs font-semibold uppercase tracking-wide text-primary/80"
          >
            Voleibol
          </p>
          <h3 class="mt-2 text-base font-semibold">Canchas de arena y piso</h3>
          <p class="mt-2 text-sm text-slate-300">
            Birrias de voleibol en formato recreativo 4v4 y 6v6. Organizadores,
            pelotas y marcador incluidos.
          </p>
        </div>

        <div class="rounded-2xl border border-white/10 bg-slate-900/40 p-4">
          <p
            class="text-xs font-semibold uppercase tracking-wide text-primary/80"
          >
            Próximamente
          </p>
          <h3 class="mt-2 text-base font-semibold">Otros deportes</h3>
          <p class="mt-2 text-sm text-slate-300">
            Estamos trabajando para sumar más deportes y más sedes. EZ PLAY está
            pensado para crecer contigo.
          </p>
        </div>
      </div>
    </div>
  </section> -->

  <!-- BENEFICIOS -->
  <section id="beneficios" class="bg-slate-950">
    <div class="mx-auto max-w-6xl px-4 py-12 md:py-16">
      <div class="grid gap-8 md:grid-cols-2 md:items-center">

         <!-- Imagen -->
        <div class="relative">
          <img
            src={benefitsImg.src}
            alt="Jugadores disfrutando un partido de voleibol organizado por EZ PLAY"
            loading="lazy"
            decoding="async"
            class="w-full h-80 md:h-[28rem] object-cover rounded-3xl border border-white/10 shadow-2xl shadow-black/30"
          />
          <div
            class="pointer-events-none absolute inset-0 rounded-3xl bg-gradient-to-tr from-slate-950/20 via-transparent to-primary/10"
          >
          </div>
        </div>

        <!-- Texto -->
        <div>
          <h2 class="text-2xl font-semibold tracking-tight sm:text-3xl">
            ¿Por qué jugar con EZ PLAY?
          </h2>
          <p class="mt-3 text-sm text-slate-300 sm:text-base">
            No es solo reservar una cancha. Es tener un equipo que se encarga de
            la logística para que cada partido se sienta como un evento
            organizado.
          </p>

          <div class="mt-6 grid gap-6 sm:grid-cols-3">
            <div class="rounded-2xl border border-white/10 bg-slate-900/60 p-4">
              <h3 class="text-base font-semibold">Organización completa</h3>
              <p class="mt-2 text-sm text-slate-300">
                Petos, balones, cronómetro, árbitro o coordinador según el
                deporte.
              </p>
            </div>
            <div class="rounded-2xl border border-white/10 bg-slate-900/60 p-4">
              <h3 class="text-base font-semibold">
                Pagos claros y cupos limitados
              </h3>
              <p class="mt-2 text-sm text-slate-300">
                Pagas solo tu espacio. Cupos definidos para asegurar buenos
                tiempos.
              </p>
            </div>
            <div class="rounded-2xl border border-white/10 bg-slate-900/60 p-4">
              <h3 class="text-base font-semibold">Comunidad en crecimiento</h3>
              <p class="mt-2 text-sm text-slate-300">
                Conoce gente nueva y arma tu grupo de birria fijo.
              </p>
            </div>
          </div>
        </div>

       
      </div>
    </div>
  </section>

  <!-- CONTACTO / CTA -->
  <section
    id="contacto"
    class="border-t border-white/5 bg-gradient-to-t from-slate-950 via-slate-950 to-slate-900"
  >
    <div class="mx-auto max-w-6xl px-4 py-12 md:py-16">
      <div class="grid gap-8 md:grid-cols-2 md:items-center">
        <!-- Texto + CTA -->
        <div class="md:order-1">
          <h2 class="text-2xl font-semibold tracking-tight sm:text-3xl">
            ¿Quieres llevar EZ PLAY a tu cancha o empresa?
          </h2>
          <p class="mt-3 text-sm text-slate-300 sm:text-base">
            Organizamos jornadas deportivas para canchas, marcas, empresas y
            comunidades. Escríbenos y conversemos cómo podemos ayudarte a llenar
            tus horarios y activar tu espacio.
          </p>

          <div
            class="mt-6 rounded-2xl border border-white/10 bg-slate-900/70 p-4"
          >
            <h3 class="text-base font-semibold">Escríbenos</h3>
            <p class="mt-2 text-sm text-slate-300">
              Puedes contactarnos directamente por correo o redes sociales:
            </p>
            <ul class="mt-4 space-y-2 text-sm text-slate-200">
              <li>
                <span class="font-semibold">Correo:</span>
                <a href="mailto:administracion@ezplayapp.com"
                  >administracion@ezplayapp.com</a
                >
              </li>
              <li>
                <span class="font-semibold">Instagram:</span>
                <a href="https://www.instagram.com/ezplaylatam" target="_blank"
                  >@ezplaylatam</a
                >
              </li>
              <li>
                <span class="font-semibold">TikTok:</span>
                <a href="https://www.tiktok.com/@ezplaylatam">@ezplaylatam</a>
              </li>
            </ul>
          </div>
        </div>
        <!-- Imagen -->
        <div class="relative md:order-2">
          <img
            src={contactImg.src}
            alt="Cancha con iluminación lista para jornada deportiva de EZ PLAY"
            loading="lazy"
            decoding="async"
            class="w-full h-72 md:h-[26rem] object-cover rounded-3xl border border-white/10 shadow-2xl shadow-black/30"
          />
          <div
            class="pointer-events-none absolute inset-0 rounded-3xl bg-gradient-to-b from-black/10 to-black/0"
          >
          </div>
        </div>
      </div>
    </div>
  </section>
</MainLayout>
